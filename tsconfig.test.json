{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client", "vitest/globals", "node", "@testing-library/jest-dom/vitest"]
  },
  "include": [
    "src/vitest.d.ts",
    "src/**/*.unit.test.ts",
    "src/**/*.component.test.tsx",
    "setup.ts",
    "src/entities/**/*",
    "src/shared/**/*"
  ]
}
